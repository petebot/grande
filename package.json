{
  "name": "grande-burrito",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Brand-led SvelteKit and Sanity website for Grande Burrito in Freeport, Maine.",
  "packageManager": "pnpm@11.15.1",
  "engines": {
    "node": ">=22 <23",
    "pnpm": ">=11 <12"
  },
  "scripts": {
    "dev": "pnpm --parallel --filter './apps/*' run dev",
    "build": "pnpm -r --if-present run build",
    "check": "pnpm run format:check && pnpm run lint && pnpm run check:design-system && pnpm run typecheck",
    "check:design-system": "node --import tsx scripts/check-design-system.ts",
    "design-system:version": "node --import tsx scripts/check-design-system-version.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "typecheck": "pnpm run typecheck:scripts && pnpm -r --if-present run check",
    "typecheck:scripts": "tsc --project tsconfig.scripts.json",
    "test": "pnpm run test:unit && pnpm run test:e2e",
    "test:unit": "pnpm -r --if-present run test:unit",
    "test:e2e": "pnpm --filter @grande/web --if-present run test:e2e",
    "test:a11y": "pnpm --filter @grande/web exec playwright test tests/e2e/brand-accessibility.spec.ts",
    "test:visual": "pnpm --filter @grande/web exec playwright test tests/e2e/visual-system.spec.ts",
    "content:snapshot": "pnpm --filter @grande/content run snapshot",
    "content:snapshot:validate": "pnpm --filter @grande/content run snapshot:validate"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@sanity/client": "^7.24.0",
    "@types/node": "^22.20.1",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.22.0",
    "globals": "^17.7.0",
    "prettier": "^3.9.6",
    "prettier-plugin-svelte": "^4.1.1",
    "tsx": "^4.23.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.65.0",
    "vitest": "^4.1.10"
  }
}

# Copy this file to .env.local for local development, or set the same keys in Vercel.
# Never commit a populated .env.local file.

# Browser-safe configuration. These values may appear in rendered pages or client bundles.
PUBLIC_SANITY_PROJECT_ID=
PUBLIC_SANITY_DATASET=
PUBLIC_SANITY_API_VERSION=
PUBLIC_SITE_URL=

# Server-only secret for authenticated draft preview. Never add a PUBLIC_ prefix.
SANITY_VIEWER_TOKEN=

# Browser-safe Sanity Studio build configuration.
SANITY_STUDIO_PROJECT_ID=
SANITY_STUDIO_DATASET=
